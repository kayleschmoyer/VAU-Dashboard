# Server Configuration
PORT=3001
NODE_ENV=production

# JWT Secret - CHANGE THIS in production
JWT_SECRET=change-this-to-a-random-secret-string

# API Key for VAU machines to authenticate status POSTs
# Share this key with your VAU installations
VAU_API_KEY=change-this-to-a-random-api-key

# Default admin credentials (used on first run to seed the database)
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=changeme

# Machine offline threshold in minutes (default: 30)
OFFLINE_THRESHOLD_MINUTES=30
