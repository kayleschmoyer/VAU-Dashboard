# Server Configuration
PORT=3001
NODE_ENV=production

# JWT secret for dashboard sessions — REQUIRED in production.
# Must be a random string of at least 32 characters, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT lifetime (jsonwebtoken format: "8h", "24h", "7d", ...)
JWT_EXPIRES_IN=24h

# API key for VAU machines to authenticate status POSTs — REQUIRED in production.
# At least 16 characters; share this key with your VAU installations.
VAU_API_KEY=

# Default admin credentials — used ONLY on first run to seed the initial user.
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASS=

# Machine offline threshold in minutes (default: 30)
OFFLINE_THRESHOLD_MINUTES=30

# SQLite database file (default: ./vau-dashboard.db). ":memory:" for ephemeral.
# DB_PATH=vau-dashboard.db

# Logging: fatal | error | warn | info | debug | trace (default: info)
# LOG_LEVEL=info

# Set when running behind a reverse proxy (IIS, nginx, Azure App Service) so
# client IPs and rate limiting are correct. "true" trusts exactly one hop.
# TRUST_PROXY=true

# Cross-origin dashboard hosts, comma-separated. Leave unset for same-origin
# deployments (the dev client uses a proxy, so this is rarely needed).
# CORS_ORIGINS=https://dashboard.example.com

# Rate limiting (per client IP)
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX=600
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=10

# bcrypt cost factor for password hashing (default: 10)
# BCRYPT_ROUNDS=10
